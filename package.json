{
	"name": "@dhsoft-inc/edc-provider-web",
	"version": "1.0.1",
	"description": "edc-provider-web (shared react utilities for Liferay portlets)",
	"repository": "https://github.com/DHSoft-Inc/edc-provider-web",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"peerDependencies": {
		"react": "18.3.1",
		"@clayui/button": "^3.143.0",
		"@clayui/core": "^3.143.0",
		"@clayui/css": "^3.127.0",
		"@clayui/modal": "^3.143.0"
	},
	"devDependencies": {
		"esbuild": "^0.20.2"
	},
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
		"build:esm": "esbuild src/index.js --bundle --format=esm --platform=browser --outfile=dist/index.mjs --loader:.js=jsx --jsx=automatic --external:react --external:@clayui/*",
		"build:cjs": "esbuild src/index.js --bundle --format=cjs --platform=browser --outfile=dist/index.cjs --loader:.js=jsx --jsx=automatic --external:react --external:@clayui/*",
		"build": "yarn clean && yarn build:esm && yarn build:cjs",
		"prepack": "yarn build",
		"publish:github": "npm publish"
	}
}